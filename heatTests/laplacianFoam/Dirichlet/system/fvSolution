FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    T
    {
        solver            AmgX;
        mode              dDDI;
        dataLocation      device;

        AmgXconfig
        {
            config_version      2;
            
            solver
            {
                scope               "main";
                solver              PCG;
                max_iters           100;
                tolerance           1e-06;
                norm                L2;
                convergence         RELATIVE_INI;
                monitor_residual    1;
                store_res_history   1;

                preconditioner
                {
                    scope               "precond";
                    solver              MULTICOLOR_DILU;
                }
            }
        }
    }
}

SIMPLE
{
    nNonOrthogonalCorrectors 2;
    residualControl
    {
        T               1e-6;
    }
}

relaxationFactors
{
    equations
    {
        T               0.8;
    }
}

