FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 250;

boundaryField
{
    emptyZ
    {
        type            empty;
    }

    "(sym1|sym2)"
    {
        type            symmetryPlane;
    }

    outerWall
    {
        type            fixedValue;
        value           uniform 200;
    }

    innerWall
    {
        type            fixedValue;
        value           uniform 300;
    }

    // innerWall
    // {
    //     type            fixedGradient;
    //     gradient        uniform 52e3;
    //     value           uniform 300;
    // }
}


