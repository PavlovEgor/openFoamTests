FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "(e|h)"
    {
        solver  GAMG;
        smoother        GaussSeidel;
        relTol  1.0E-5;
        cacheAgglomeration      true;
        nFinestSweeps   2;
        nPreSweeps      0;
        maxIter         500;
        nPostSweeps     1;
        agglomerator    faceAreaPair;
        nCellsInCoarsestLevel   10;
        tolerance       1.0E-7;
        mergeLevels     1;
    }
}

SIMPLE
{
    nNonOrthogonalCorrectors 2;
    residualControl
    {
        "(e|h)"               1e-4;
    }
}

relaxationFactors
{
    equations
    {
        "(e|h)"               1.0;
    }
}

