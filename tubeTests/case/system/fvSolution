FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    p
    {
        solver            AmgX;
        mode              dDDI;
        dataLocation      device;

        // AmgXconfigPath       "$WM_PROJECT_USER_DIR/run/openFoamTests/tubeTests/case/system/FGMRES_CLASSICAL_AGGRESSIVE_PMIS.json";
    AmgXconfig
    {
        config_version      2;
        
        solver
        {
            scope               "main";
            solver              FGMRES;
            max_iters           100;
            tolerance           1e-6;
            norm                L2;
            convergence         RELATIVE_INI;
            monitor_residual    1;        
            // print_solve_stats   1;
            // obtain_timings      1;
            gmres_n_restart     20;
            store_res_history   1;
            
            preconditioner
            {
                scope               "amg";
                solver              AMG;
                max_iters           1;
                cycle               V;
                presweeps           1;
                postsweeps          1;
                interpolator        D2;
                monitor_residual    1;        
                store_res_history   1;        
                print_solve_stats   0;
                // print_grid_stats    1;
                print_vis_data      0;
            }
        }
    }
    }


    "(U|Ux|Uy|Uz|k|epsilon)"
    {
        solver            AmgX;
        mode              dDDI;
        dataLocation      device;

        // AmgXconfigPath       "$WM_PROJECT_USER_DIR/run/openFoamTests/tubeTests/case/system/PBICGSTAB_CLASSICAL_JACOBI.json";
    AmgXconfig
    {
        config_version      2;
        
        solver
        {
            scope               "main";
            solver              FGMRES;
            max_iters           100;
            tolerance           1e-6;
            norm                L2;
            convergence         RELATIVE_INI;
            monitor_residual    1;        
            // print_solve_stats   1;
            // obtain_timings      1;
            gmres_n_restart     20;
            store_res_history   1;
            
            preconditioner
            {
                scope               "amg";
                solver              AMG;
                max_iters           1;
                cycle               V;
                presweeps           1;
                postsweeps          1;
                interpolator        D2;
                monitor_residual    1;        
                store_res_history   1;        
                print_solve_stats   0;
                // print_grid_stats    1;
                print_vis_data      0;
            }
        }
    }
    }

    cellDisplacement
    {
        $p;
        relTol          0;
    }
}

SIMPLE
{
    nNonOrthogonalCorrectors 2;

    residualControl
    {
        p               1e-4;
        "(U|Ux|Uy|Uz)"             1e-6;
        "(k|epsilon|omega)" 1e-6;
    }
}

relaxationFactors
{
    fields { p           0.7;
    }
    equations { "(U|Ux|Uy|Uz)"               0.65;
        "(k|epsilon)"   0.7;
    }
}

